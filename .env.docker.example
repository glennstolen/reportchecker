# ── E-post / magic link (Brevo) ───────────────────────────
# Opprett gratis konto på brevo.com, gå til SMTP & API → SMTP
# Verifiser avsenderadressen under Senders & IP → Senders
# Tom SMTP_USER = lenken printes kun i backend-loggen
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=                        # din Brevo-innloggingsepost
SMTP_PASSWORD=                    # SMTP-nøkkel fra Brevo
SMTP_FROM=din@epost.no            # må være verifisert i Brevo
