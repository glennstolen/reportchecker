# Anthropic API Key (required for AI evaluation)
ANTHROPIC_API_KEY=your_api_key_here

# Database (auto-configured in docker-compose, only needed for local dev)
DATABASE_URL=postgresql://reportchecker:reportchecker_dev@localhost:5432/reportchecker

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=reports
